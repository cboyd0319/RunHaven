FROM node:26.3.0-trixie-slim@sha256:95a34da32a840bd9b3b09a5b773591c16923e350174b1c50e1200c75bf15eaa9

ARG DEBIAN_FRONTEND=noninteractive

COPY common/debian.sources /etc/apt/sources.list.d/debian.sources
COPY common/apt-snapshot.conf /etc/apt/apt.conf.d/99snapshot
COPY common/debian-packages.txt /tmp/debian-packages.txt
COPY common/create-agent-user.sh /usr/local/sbin/create-agent-user
COPY claude/package.json claude/package-lock.json /opt/mca-agent/

RUN apt-get update \
    && xargs -a /tmp/debian-packages.txt apt-get install -y --no-install-recommends \
    && rm -rf /var/lib/apt/lists/* /tmp/debian-packages.txt

RUN npm install -g npm@11.17.0 --no-audit --no-fund --ignore-scripts --allow-git=none --allow-file=none --allow-directory=none \
    && npm cache clean --force

WORKDIR /opt/mca-agent
RUN npm ci --omit=dev --no-audit --no-fund --strict-allow-scripts=true --allow-git=none --allow-file=none --allow-directory=none \
    && for binary in /opt/mca-agent/node_modules/.bin/*; do ln -sf "${binary}" "/usr/local/bin/$(basename "${binary}")"; done \
    && npm cache clean --force

RUN /bin/sh /usr/local/sbin/create-agent-user \
    && rm /usr/local/sbin/create-agent-user

ENV HOME=/home/agent
ENV PATH=/opt/mca-agent/node_modules/.bin:/home/agent/.local/bin:/usr/local/bin:/usr/bin:/bin
ENV CLAUDE_CONFIG_DIR=/home/agent/.claude

WORKDIR /workspace
USER agent
CMD ["claude"]
